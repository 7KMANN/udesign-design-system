{
  "name": "udesign-design-system",
  "version": "1.3.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "UDesign semantic tokens and versioned shadcn source registry for branded applications.",
  "type": "module",
  "main": "dist/tokens.css",
  "files": [
    "dist",
    "tokens",
    "registry",
    "registry.json",
    "public/r",
    "README.md",
    "DESIGN.md",
    "HANDOFF.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:registry": "shadcn build registry.json --output public/r",
    "release": "node scripts/release.mjs",
    "dev": "vite",
    "dev:test": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "test": "npm run test:contracts && npm run test:components",
    "test:contracts": "node --test tests/design-utils.test.mjs tests/release-utils.test.mjs tests/token-contract.test.mjs tests/contrast.test.mjs && node scripts/test-registry.mjs",
    "test:components": "vitest run",
    "test:e2e": "playwright test",
    "test:registry-install": "node scripts/test-registry-install.mjs",
    "typecheck:registry": "tsc -p registry/tsconfig.json",
    "build-showcase": "tsc && vite build",
    "validate": "npm run build && node scripts/lint-design.mjs && npm run build:registry && npm run test:contracts && npm run typecheck:registry && npm run test:components && npm run test:registry-install && npm run build-showcase && npm run test:e2e"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.435.0",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^3.5.0",
    "style-dictionary": "^4.0.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
