{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "UDesign design system. Source of truth (DTCG 2025.10). Compile with Style Dictionary to dist/tokens.css and other platforms. Primitives first, then functional roles that components consume.",

  "color": {
    "$type": "color",

    "accent": {
      "$description": "The UDesign accent. Not 'gold': this is the brand color.",
      "wash":  { "$value": { "colorSpace": "srgb", "components": [0.953, 0.918, 0.851], "hex": "#f3ead9" } },
      "300":   { "$value": { "colorSpace": "srgb", "components": [0.871, 0.773, 0.651], "hex": "#dec5a6" } },
      "400":   { "$value": { "colorSpace": "srgb", "components": [0.824, 0.698, 0.537], "hex": "#d2b289" } },
      "base":  { "$value": { "colorSpace": "srgb", "components": [0.780, 0.624, 0.420], "hex": "#c79f6b" } },
      "deep":  { "$description": "WCAG-safe accent for text on cream/white.", "$value": { "colorSpace": "srgb", "components": [0.620, 0.459, 0.271], "hex": "#9e7545" } }
    },

    "cream": { "$value": { "colorSpace": "srgb", "components": [0.957, 0.925, 0.882], "hex": "#f4ece1" } },
    "ink":   { "$value": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "hex": "#1b1b1b" } },
    "white": { "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#ffffff" } },

    "neutral": {
      "$description": "Warm stone. Deliberately never cold slate.",
      "panel":        { "$value": { "colorSpace": "srgb", "components": [0.957, 0.945, 0.918], "hex": "#f4f1ea" } },
      "panel-2":      { "$value": { "colorSpace": "srgb", "components": [0.937, 0.914, 0.867], "hex": "#efe9dd" } },
      "border":       { "$value": { "colorSpace": "srgb", "components": [0.894, 0.871, 0.816], "hex": "#e4ded0" } },
      "border-strong":{ "$value": { "colorSpace": "srgb", "components": [0.839, 0.804, 0.725], "hex": "#d6cdb9" } },
      "muted":        { "$value": { "colorSpace": "srgb", "components": [0.541, 0.506, 0.447], "hex": "#8a8172" } },
      "muted-soft":   { "$value": { "colorSpace": "srgb", "components": [0.718, 0.686, 0.624], "hex": "#b7af9f" } }
    },

    "status": {
      "success":    { "$value": { "colorSpace": "srgb", "components": [0.247, 0.490, 0.306], "hex": "#3f7d4e" } },
      "success-bg": { "$value": { "colorSpace": "srgb", "components": [0.906, 0.941, 0.906], "hex": "#e7f0e7" } },
      "warning":    { "$value": { "colorSpace": "srgb", "components": [0.718, 0.475, 0.122], "hex": "#b7791f" } },
      "warning-bg": { "$value": { "colorSpace": "srgb", "components": [0.969, 0.937, 0.867], "hex": "#f7efdd" } },
      "danger":     { "$value": { "colorSpace": "srgb", "components": [0.698, 0.227, 0.184], "hex": "#b23a2f" } },
      "danger-bg":  { "$value": { "colorSpace": "srgb", "components": [0.965, 0.902, 0.890], "hex": "#f6e6e3" } }
    }
  },

  "role": {
    "$type": "color",
    "$description": "Functional roles components consume, in the globalvision/shadcn naming. Aliases into color primitives.",
    "background":        { "$value": "{color.cream}" },
    "foreground":        { "$value": "{color.ink}" },
    "card":              { "$value": "{color.white}" },
    "card-foreground":   { "$value": "{color.ink}" },
    "popover":           { "$value": "{color.white}" },
    "popover-foreground":{ "$value": "{color.ink}" },
    "backdrop":          { "$description": "Theme-stable modal scrim base.", "$value": "{color.ink}" },
    "primary":           { "$value": "{color.accent.base}" },
    "primary-foreground":{ "$value": "{color.ink}" },
    "primary-hover":     { "$value": "{color.accent.deep}" },
    "secondary":         { "$value": "{color.neutral.panel}" },
    "secondary-foreground": { "$value": "{color.ink}" },
    "muted":             { "$value": "{color.neutral.panel}" },
    "muted-foreground":  { "$description": "AA-safe quiet text on the muted surface.", "$value": { "colorSpace": "srgb", "components": [0.439, 0.404, 0.349], "hex": "#706759" } },
    "accent":            { "$value": "{color.accent.wash}" },
    "accent-foreground": { "$value": "{color.ink}" },
    "border":            { "$value": "{color.neutral.border}" },
    "border-strong":     { "$value": "{color.neutral.border-strong}" },
    "input":             { "$value": "{color.neutral.border-strong}" },
    "ring":              { "$value": "{color.accent.base}" },
    "destructive":       { "$value": "{color.status.danger}" },
    "destructive-foreground": { "$value": "{color.white}" },
    "sidebar":           { "$value": "{color.neutral.panel}" },
    "sidebar-foreground":{ "$value": "{color.ink}" },
    "sidebar-primary":   { "$value": "{color.accent.base}" },
    "sidebar-primary-foreground": { "$value": "{color.ink}" },
    "sidebar-accent":    { "$value": "{color.accent.wash}" },
    "sidebar-accent-foreground": { "$value": "{color.ink}" },
    "sidebar-border":    { "$value": "{color.neutral.border}" },
    "sidebar-ring":      { "$value": "{color.accent.base}" },
    "client":            { "$description": "Adaptive per-page accent. Overridden with the client's own brand color; everything else stays fixed.", "$value": "{color.accent.base}" }
  },

  "tone": {
    "$type": "color",
    "$description": "Reusable visual semantics. Applications map domain states to these tones.",
    "neutral": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.31, 0.275, 0.231], "hex": "#4f463b" } },
      "surface": { "$value": { "colorSpace": "srgb", "components": [0.945, 0.933, 0.91], "hex": "#f1eee8" } },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.718, 0.686, 0.624], "hex": "#b7af9f" } },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.373, 0.341, 0.298], "hex": "#5f574c" } },
      "solid-foreground": { "$value": "{color.white}" }
    },
    "info": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.141, 0.337, 0.478], "hex": "#24567a" } },
      "surface": { "$value": { "colorSpace": "srgb", "components": [0.906, 0.949, 0.973], "hex": "#e7f2f8" } },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.49, 0.722, 0.851], "hex": "#7db8d9" } },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.153, 0.404, 0.561], "hex": "#27678f" } },
      "solid-foreground": { "$value": "{color.white}" }
    },
    "success": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.157, 0.384, 0.227], "hex": "#28623a" } },
      "surface": { "$value": "{color.status.success-bg}" },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.455, 0.678, 0.502], "hex": "#74ad80" } },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.196, 0.451, 0.275], "hex": "#327346" } },
      "solid-foreground": { "$value": "{color.white}" }
    },
    "warning": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.435, 0.278, 0], "hex": "#6f4700" } },
      "surface": { "$value": "{color.status.warning-bg}" },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.745, 0.58, 0.259], "hex": "#be9442" } },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.463, 0.314, 0], "hex": "#765000" } },
      "solid-foreground": { "$value": "{color.white}" }
    },
    "danger": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.549, 0.176, 0.149], "hex": "#8c2d26" } },
      "surface": { "$value": "{color.status.danger-bg}" },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.788, 0.42, 0.38], "hex": "#c96b61" } },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.608, 0.2, 0.169], "hex": "#9b332b" } },
      "solid-foreground": { "$value": "{color.white}" }
    },
    "progress": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.353, 0.259, 0.573], "hex": "#5a4292" } },
      "surface": { "$value": { "colorSpace": "srgb", "components": [0.933, 0.914, 0.98], "hex": "#eee9fa" } },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.624, 0.529, 0.808], "hex": "#9f87ce" } },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.396, 0.286, 0.647], "hex": "#6549a5" } },
      "solid-foreground": { "$value": "{color.white}" }
    },
    "brand": {
      "foreground": { "$value": { "colorSpace": "srgb", "components": [0.459, 0.322, 0.18], "hex": "#75522e" } },
      "surface": { "$value": "{color.accent.wash}" },
      "border": { "$value": "{color.accent.400}" },
      "solid": { "$value": { "colorSpace": "srgb", "components": [0.478, 0.341, 0.184], "hex": "#7a572f" } },
      "solid-foreground": { "$value": "{color.white}" }
    }
  },

  "metric": {
    "$type": "color",
    "$description": "Value-change semantics, intentionally separate from operational status.",
    "positive": { "foreground": { "$value": "{tone.success.foreground}" }, "surface": { "$value": "{tone.success.surface}" }, "border": { "$value": "{tone.success.border}" } },
    "negative": { "foreground": { "$value": "{tone.danger.foreground}" }, "surface": { "$value": "{tone.danger.surface}" }, "border": { "$value": "{tone.danger.border}" } },
    "neutral": { "foreground": { "$value": "{tone.neutral.foreground}" }, "surface": { "$value": "{tone.neutral.surface}" }, "border": { "$value": "{tone.neutral.border}" } }
  },

  "data": {
    "$type": "color",
    "1": { "$value": { "colorSpace": "srgb", "components": [0.153, 0.404, 0.561], "hex": "#27678f" } },
    "2": { "$value": { "colorSpace": "srgb", "components": [0.196, 0.451, 0.275], "hex": "#327346" } },
    "3": { "$value": { "colorSpace": "srgb", "components": [0.698, 0.412, 0.102], "hex": "#b2691a" } },
    "4": { "$value": { "colorSpace": "srgb", "components": [0.396, 0.286, 0.647], "hex": "#6549a5" } },
    "5": { "$value": { "colorSpace": "srgb", "components": [0.655, 0.235, 0.416], "hex": "#a73c6a" } },
    "6": { "$value": { "colorSpace": "srgb", "components": [0.078, 0.482, 0.494], "hex": "#147b7e" } },
    "7": { "$value": { "colorSpace": "srgb", "components": [0.608, 0.2, 0.169], "hex": "#9b332b" } },
    "8": { "$value": { "colorSpace": "srgb", "components": [0.478, 0.341, 0.184], "hex": "#7a572f" } },
    "muted": { "$value": "{color.neutral.muted-soft}" },
    "grid": { "$value": "{color.neutral.border}" },
    "axis": { "$value": "{color.neutral.muted}" },
    "tooltip": { "$value": "{color.ink}" },
    "tooltip-foreground": { "$value": "{color.white}" }
  },

  "entity": {
    "$type": "color",
    "1": { "foreground": { "$value": "{tone.info.foreground}" }, "surface": { "$value": "{tone.info.surface}" }, "border": { "$value": "{tone.info.border}" }, "solid": { "$value": "{tone.info.solid}" } },
    "2": { "foreground": { "$value": "{tone.progress.foreground}" }, "surface": { "$value": "{tone.progress.surface}" }, "border": { "$value": "{tone.progress.border}" }, "solid": { "$value": "{tone.progress.solid}" } },
    "3": { "foreground": { "$value": "{tone.success.foreground}" }, "surface": { "$value": "{tone.success.surface}" }, "border": { "$value": "{tone.success.border}" }, "solid": { "$value": "{tone.success.solid}" } },
    "4": { "foreground": { "$value": "{tone.brand.foreground}" }, "surface": { "$value": "{tone.brand.surface}" }, "border": { "$value": "{tone.brand.border}" }, "solid": { "$value": "{tone.brand.solid}" } }
  },

  "interactive": {
    "$type": "color",
    "hover": { "$value": "{color.neutral.panel}" },
    "pressed": { "$value": "{color.neutral.panel-2}" },
    "selected": { "$value": "{color.accent.wash}" },
    "selected-foreground": { "$value": "{color.ink}" },
    "selected-border": { "$value": "{color.accent.deep}" },
    "focus": { "$value": "{color.accent.base}" },
    "disabled": { "$value": "{color.neutral.panel-2}" },
    "disabled-foreground": { "$value": "{color.neutral.muted}" }
  },

  "surface": {
    "$type": "color",
    "raised": { "$value": "{color.white}" },
    "raised-foreground": { "$value": "{color.ink}" },
    "sunken": { "$value": "{color.neutral.panel-2}" },
    "sunken-foreground": { "$value": "{color.ink}" },
    "overlay": { "$value": "{color.white}" },
    "overlay-foreground": { "$value": "{color.ink}" },
    "console": { "$value": "{color.ink}" },
    "console-foreground": { "$value": "{color.white}" }
  },

  "responsive": {
    "$description": "Shared mobile and touch ergonomics contracts.",
    "touch-target-min": { "$type": "dimension", "$value": { "value": 44, "unit": "px" } },
    "control-height": { "$type": "dimension", "$value": { "value": 44, "unit": "px" } },
    "control-height-compact": { "$type": "dimension", "$value": { "value": 36, "unit": "px" } },
    "content-gutter-mobile": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
    "dialog-inline-size-mobile": { "$type": "dimension", "$value": { "value": 95, "unit": "vw" } },
    "dialog-block-size-max": { "$type": "dimension", "$value": { "value": 100, "unit": "svh" } },
    "safe-area-bottom": { "$type": "string", "$value": "env(safe-area-inset-bottom, 0px)" }
  },

  "dark": {
    "$description": "Dark-mode semantic overrides. These compose with either design profile.",
    "role": {
      "$type": "color",
      "background": { "$value": { "colorSpace": "srgb", "components": [0.09, 0.082, 0.071], "hex": "#171512" } },
      "foreground": { "$value": "{color.neutral.panel}" },
      "card": { "$value": { "colorSpace": "srgb", "components": [0.129, 0.118, 0.102], "hex": "#211e1a" } },
      "card-foreground": { "$value": "{color.neutral.panel}" },
      "popover": { "$value": { "colorSpace": "srgb", "components": [0.129, 0.118, 0.102], "hex": "#211e1a" } },
      "popover-foreground": { "$value": "{color.neutral.panel}" },
      "primary": { "$value": "{color.accent.300}" },
      "primary-foreground": { "$value": "{color.ink}" },
      "primary-hover": { "$value": "{color.accent.400}" },
      "secondary": { "$value": { "colorSpace": "srgb", "components": [0.169, 0.153, 0.133], "hex": "#2b2722" } },
      "secondary-foreground": { "$value": "{color.neutral.panel}" },
      "muted": { "$value": { "colorSpace": "srgb", "components": [0.169, 0.153, 0.133], "hex": "#2b2722" } },
      "muted-foreground": { "$value": { "colorSpace": "srgb", "components": [0.769, 0.725, 0.659], "hex": "#c4b9a8" } },
      "accent": { "$value": { "colorSpace": "srgb", "components": [0.22, 0.184, 0.145], "hex": "#382f25" } },
      "accent-foreground": { "$value": "{color.neutral.panel}" },
      "border": { "$value": { "colorSpace": "srgb", "components": [0.278, 0.251, 0.212], "hex": "#474036" } },
      "border-strong": { "$value": { "colorSpace": "srgb", "components": [0.412, 0.369, 0.306], "hex": "#695e4e" } },
      "input": { "$value": { "colorSpace": "srgb", "components": [0.412, 0.369, 0.306], "hex": "#695e4e" } },
      "ring": { "$value": "{color.accent.300}" },
      "destructive": { "$value": { "colorSpace": "srgb", "components": [0.631, 0.251, 0.216], "hex": "#a14037" } },
      "destructive-foreground": { "$value": "{color.white}" },
      "sidebar": { "$value": { "colorSpace": "srgb", "components": [0.106, 0.098, 0.086], "hex": "#1b1916" } },
      "sidebar-foreground": { "$value": "{color.neutral.panel}" },
      "sidebar-primary": { "$value": "{color.accent.300}" },
      "sidebar-primary-foreground": { "$value": "{color.ink}" },
      "sidebar-accent": { "$value": { "colorSpace": "srgb", "components": [0.22, 0.184, 0.145], "hex": "#382f25" } },
      "sidebar-accent-foreground": { "$value": "{color.neutral.panel}" },
      "sidebar-border": { "$value": { "colorSpace": "srgb", "components": [0.278, 0.251, 0.212], "hex": "#474036" } },
      "sidebar-ring": { "$value": "{color.accent.300}" }
    },
    "tone": {
      "$type": "color",
      "neutral": {
        "foreground": { "$value": { "colorSpace": "srgb", "components": [0.843, 0.812, 0.757], "hex": "#d7cfc1" } },
        "surface": { "$value": { "colorSpace": "srgb", "components": [0.153, 0.141, 0.122], "hex": "#27241f" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.365, 0.337, 0.294], "hex": "#5d564b" } },
        "solid": { "$value": { "colorSpace": "srgb", "components": [0.78, 0.741, 0.675], "hex": "#c7bdac" } },
        "solid-foreground": { "$value": "{color.ink}" }
      },
      "info": {
        "foreground": { "$value": { "colorSpace": "srgb", "components": [0.596, 0.784, 0.89], "hex": "#98c8e3" } },
        "surface": { "$value": { "colorSpace": "srgb", "components": [0.075, 0.169, 0.227], "hex": "#132b3a" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.263, 0.522, 0.667], "hex": "#4385aa" } },
        "solid": { "$value": { "colorSpace": "srgb", "components": [0.475, 0.729, 0.875], "hex": "#79badf" } },
        "solid-foreground": { "$value": "{color.ink}" }
      },
      "success": {
        "foreground": { "$value": { "colorSpace": "srgb", "components": [0.62, 0.808, 0.659], "hex": "#9ecfa8" } },
        "surface": { "$value": { "colorSpace": "srgb", "components": [0.09, 0.2, 0.118], "hex": "#17331e" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.333, 0.588, 0.388], "hex": "#559663" } },
        "solid": { "$value": { "colorSpace": "srgb", "components": [0.49, 0.741, 0.545], "hex": "#7dbd8b" } },
        "solid-foreground": { "$value": "{color.ink}" }
      },
      "warning": {
        "foreground": { "$value": { "colorSpace": "srgb", "components": [0.925, 0.761, 0.455], "hex": "#ecc274" } },
        "surface": { "$value": { "colorSpace": "srgb", "components": [0.224, 0.145, 0.027], "hex": "#392507" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.639, 0.475, 0.169], "hex": "#a3792b" } },
        "solid": { "$value": { "colorSpace": "srgb", "components": [0.878, 0.706, 0.373], "hex": "#e0b45f" } },
        "solid-foreground": { "$value": "{color.ink}" }
      },
      "danger": {
        "foreground": { "$value": { "colorSpace": "srgb", "components": [0.941, 0.647, 0.616], "hex": "#f0a59d" } },
        "surface": { "$value": { "colorSpace": "srgb", "components": [0.243, 0.102, 0.086], "hex": "#3e1a16" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.663, 0.341, 0.31], "hex": "#a9574f" } },
        "solid": { "$value": { "colorSpace": "srgb", "components": [0.886, 0.541, 0.502], "hex": "#e28a80" } },
        "solid-foreground": { "$value": "{color.ink}" }
      },
      "progress": {
        "foreground": { "$value": { "colorSpace": "srgb", "components": [0.78, 0.714, 0.929], "hex": "#c7b6ed" } },
        "surface": { "$value": { "colorSpace": "srgb", "components": [0.157, 0.118, 0.243], "hex": "#281e3e" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.467, 0.369, 0.675], "hex": "#775eac" } },
        "solid": { "$value": { "colorSpace": "srgb", "components": [0.714, 0.631, 0.882], "hex": "#b6a1e1" } },
        "solid-foreground": { "$value": "{color.ink}" }
      },
      "brand": {
