        "surface": { "$value": { "colorSpace": "srgb", "components": [0.22, 0.184, 0.145], "hex": "#382f25" } },
        "border": { "$value": { "colorSpace": "srgb", "components": [0.553, 0.435, 0.298], "hex": "#8d6f4c" } },
        "solid": { "$value": "{color.accent.300}" },
        "solid-foreground": { "$value": "{color.ink}" }
      }
    },
    "data": {
      "$type": "color",
      "1": { "$value": { "colorSpace": "srgb", "components": [0.596, 0.784, 0.89], "hex": "#98c8e3" } },
      "2": { "$value": { "colorSpace": "srgb", "components": [0.62, 0.812, 0.659], "hex": "#9ecfa8" } },
      "3": { "$value": { "colorSpace": "srgb", "components": [0.925, 0.761, 0.455], "hex": "#ecc274" } },
      "4": { "$value": { "colorSpace": "srgb", "components": [0.78, 0.714, 0.929], "hex": "#c7b6ed" } },
      "5": { "$value": { "colorSpace": "srgb", "components": [0.89, 0.627, 0.741], "hex": "#e3a0bd" } },
      "6": { "$value": { "colorSpace": "srgb", "components": [0.506, 0.788, 0.753], "hex": "#81c9c0" } },
      "7": { "$value": { "colorSpace": "srgb", "components": [0.941, 0.647, 0.616], "hex": "#f0a59d" } },
      "8": { "$value": { "colorSpace": "srgb", "components": [0.89, 0.792, 0.671], "hex": "#e3caab" } },
      "muted": { "$value": { "colorSpace": "srgb", "components": [0.412, 0.369, 0.306], "hex": "#695e4e" } },
      "grid": { "$value": { "colorSpace": "srgb", "components": [0.278, 0.251, 0.212], "hex": "#474036" } },
      "axis": { "$value": { "colorSpace": "srgb", "components": [0.769, 0.725, 0.659], "hex": "#c4b9a8" } },
      "tooltip": { "$value": "{color.neutral.panel}" },
      "tooltip-foreground": { "$value": "{color.ink}" }
    },
    "interactive": {
      "$type": "color",
      "hover": { "$value": { "colorSpace": "srgb", "components": [0.169, 0.153, 0.133], "hex": "#2b2722" } },
      "pressed": { "$value": { "colorSpace": "srgb", "components": [0.22, 0.196, 0.165], "hex": "#38322a" } },
      "selected": { "$value": { "colorSpace": "srgb", "components": [0.22, 0.184, 0.145], "hex": "#382f25" } },
      "selected-foreground": { "$value": "{color.neutral.panel}" },
      "selected-border": { "$value": "{color.accent.300}" },
      "focus": { "$value": "{color.accent.300}" },
      "disabled": { "$value": { "colorSpace": "srgb", "components": [0.153, 0.141, 0.122], "hex": "#27241f" } },
      "disabled-foreground": { "$value": { "colorSpace": "srgb", "components": [0.557, 0.518, 0.455], "hex": "#8e8474" } }
    },
    "surface": {
      "$type": "color",
      "raised": { "$value": { "colorSpace": "srgb", "components": [0.129, 0.118, 0.102], "hex": "#211e1a" } },
      "raised-foreground": { "$value": "{color.neutral.panel}" },
      "sunken": { "$value": { "colorSpace": "srgb", "components": [0.071, 0.063, 0.055], "hex": "#12100e" } },
      "sunken-foreground": { "$value": "{color.neutral.panel}" },
      "overlay": { "$value": { "colorSpace": "srgb", "components": [0.169, 0.153, 0.133], "hex": "#2b2722" } },
      "overlay-foreground": { "$value": "{color.neutral.panel}" },
      "console": { "$value": { "colorSpace": "srgb", "components": [0.035, 0.031, 0.027], "hex": "#090807" } },
      "console-foreground": { "$value": { "colorSpace": "srgb", "components": [0.749, 0.875, 0.718], "hex": "#bfdfb7" } }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$description": "Impact + UI. From udesign-website.", "$value": ["Montserrat", "sans-serif"] },
      "body":    { "$description": "Readable application and long-form text.", "$value": ["Geist", "system-ui", "sans-serif"] },
      "data":    { "$description": "Technical readouts only: SKU, PMS, dimensions.", "$value": ["JetBrains Mono", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium":  { "$value": 500 },
      "semibold":{ "$value": 600 },
      "bold":    { "$value": 700 },
      "extrabold": { "$value": 800 },
      "black":   { "$value": 900 }
    }
  },

  "typography": {
    "$type": "typography",
    "display": { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.black}", "fontSize": { "value": 3, "unit": "rem" }, "lineHeight": 1, "letterSpacing": { "value": -0.02, "unit": "em" } } },
    "h1":      { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.black}", "fontSize": { "value": 2.1, "unit": "rem" }, "lineHeight": 1.05, "letterSpacing": { "value": -0.01, "unit": "em" } } },
    "h2":      { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.extrabold}", "fontSize": { "value": 1.6, "unit": "rem" }, "lineHeight": 1.1, "letterSpacing": { "value": -0.01, "unit": "em" } } },
    "h3":      { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.bold}", "fontSize": { "value": 1.2, "unit": "rem" }, "lineHeight": 1.2, "letterSpacing": { "value": 0, "unit": "em" } } },
    "body":    { "$value": { "fontFamily": "{font.family.body}", "fontWeight": "{font.weight.regular}", "fontSize": { "value": 1, "unit": "rem" }, "lineHeight": 1.6, "letterSpacing": { "value": 0, "unit": "em" } } },
    "label":   { "$description": "Quiet Title-case label. Never uppercase, never wide-tracked, never mono.", "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.semibold}", "fontSize": { "value": 0.78, "unit": "rem" }, "lineHeight": 1.3, "letterSpacing": { "value": 0, "unit": "em" } } },
    "data":    { "$value": { "fontFamily": "{font.family.data}", "fontWeight": "{font.weight.regular}", "fontSize": { "value": 0.85, "unit": "rem" }, "lineHeight": 1.4, "letterSpacing": { "value": 0, "unit": "em" } } }
  },

  "radius": {
    "$type": "dimension",
    "sm":   { "$value": { "value": 7, "unit": "px" } },
    "base": { "$description": "Shared with globalvision (0.625rem).", "$value": { "value": 10, "unit": "px" } },
    "lg":   { "$value": { "value": 16, "unit": "px" } },
    "pill": { "$value": { "value": 999, "unit": "px" } }
  },

  "space": {
    "$type": "dimension",
    "1": { "$value": { "value": 0.25, "unit": "rem" } },
    "2": { "$value": { "value": 0.5, "unit": "rem" } },
    "3": { "$value": { "value": 0.75, "unit": "rem" } },
    "4": { "$value": { "value": 1, "unit": "rem" } },
    "6": { "$value": { "value": 1.5, "unit": "rem" } },
    "8": { "$value": { "value": 2, "unit": "rem" } }
  },

  "shadow": {
    "$type": "shadow",
    "1": { "$value": { "color": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "alpha": 0.05, "hex": "#1b1b1b" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1, "unit": "px" }, "blur": { "value": 2, "unit": "px" }, "spread": { "value": 0, "unit": "px" } } },
    "2": { "$value": { "color": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "alpha": 0.28, "hex": "#1b1b1b" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 8, "unit": "px" }, "blur": { "value": 24, "unit": "px" }, "spread": { "value": -14, "unit": "px" } } },
    "3": { "$value": { "color": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "alpha": 0.40, "hex": "#1b1b1b" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 24, "unit": "px" }, "blur": { "value": 60, "unit": "px" }, "spread": { "value": -34, "unit": "px" } } }
  }
}
