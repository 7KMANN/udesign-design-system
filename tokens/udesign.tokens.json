{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "UDesign design system. Source of truth (DTCG 2025.10). Compile with Style Dictionary to dist/tokens.css and other platforms. Primitives first, then functional roles that components consume.",

  "color": {
    "$type": "color",

    "accent": {
      "$description": "The UDesign accent. Not 'gold': this is the brand color.",
      "wash":  { "$value": { "colorSpace": "srgb", "components": [0.953, 0.918, 0.851], "hex": "#f3ead9" } },
      "300":   { "$value": { "colorSpace": "srgb", "components": [0.871, 0.773, 0.651], "hex": "#dec5a6" } },
      "400":   { "$value": { "colorSpace": "srgb", "components": [0.824, 0.698, 0.537], "hex": "#d2b289" } },
      "base":  { "$value": { "colorSpace": "srgb", "components": [0.780, 0.624, 0.420], "hex": "#c79f6b" } },
      "deep":  { "$description": "WCAG-safe accent for text on cream/white.", "$value": { "colorSpace": "srgb", "components": [0.620, 0.459, 0.271], "hex": "#9e7545" } }
    },

    "cream": { "$value": { "colorSpace": "srgb", "components": [0.957, 0.925, 0.882], "hex": "#f4ece1" } },
    "ink":   { "$value": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "hex": "#1b1b1b" } },
    "white": { "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#ffffff" } },

    "neutral": {
      "$description": "Warm stone. Deliberately never cold slate.",
      "panel":        { "$value": { "colorSpace": "srgb", "components": [0.957, 0.945, 0.918], "hex": "#f4f1ea" } },
      "panel-2":      { "$value": { "colorSpace": "srgb", "components": [0.937, 0.914, 0.867], "hex": "#efe9dd" } },
      "border":       { "$value": { "colorSpace": "srgb", "components": [0.894, 0.871, 0.816], "hex": "#e4ded0" } },
      "border-strong":{ "$value": { "colorSpace": "srgb", "components": [0.839, 0.804, 0.725], "hex": "#d6cdb9" } },
      "muted":        { "$value": { "colorSpace": "srgb", "components": [0.541, 0.506, 0.447], "hex": "#8a8172" } },
      "muted-soft":   { "$value": { "colorSpace": "srgb", "components": [0.718, 0.686, 0.624], "hex": "#b7af9f" } }
    },

    "status": {
      "success":    { "$value": { "colorSpace": "srgb", "components": [0.247, 0.490, 0.306], "hex": "#3f7d4e" } },
      "success-bg": { "$value": { "colorSpace": "srgb", "components": [0.906, 0.941, 0.906], "hex": "#e7f0e7" } },
      "warning":    { "$value": { "colorSpace": "srgb", "components": [0.718, 0.475, 0.122], "hex": "#b7791f" } },
      "warning-bg": { "$value": { "colorSpace": "srgb", "components": [0.969, 0.937, 0.867], "hex": "#f7efdd" } },
      "danger":     { "$value": { "colorSpace": "srgb", "components": [0.698, 0.227, 0.184], "hex": "#b23a2f" } },
      "danger-bg":  { "$value": { "colorSpace": "srgb", "components": [0.965, 0.902, 0.890], "hex": "#f6e6e3" } }
    }
  },

  "role": {
    "$type": "color",
    "$description": "Functional roles components consume, in the globalvision/shadcn naming. Aliases into color primitives.",
    "background":        { "$value": "{color.cream}" },
    "foreground":        { "$value": "{color.ink}" },
    "card":              { "$value": "{color.white}" },
    "card-foreground":   { "$value": "{color.ink}" },
    "primary":           { "$value": "{color.accent.base}" },
    "primary-foreground":{ "$value": "{color.ink}" },
    "primary-hover":     { "$value": "{color.accent.deep}" },
    "secondary":         { "$value": "{color.neutral.panel}" },
    "secondary-foreground": { "$value": "{color.ink}" },
    "muted":             { "$value": "{color.neutral.panel}" },
    "muted-foreground":  { "$value": "{color.neutral.muted}" },
    "border":            { "$value": "{color.neutral.border}" },
    "border-strong":     { "$value": "{color.neutral.border-strong}" },
    "ring":              { "$value": "{color.accent.base}" },
    "destructive":       { "$value": "{color.status.danger}" },
    "client":            { "$description": "Adaptive per-page accent. Overridden with the client's own brand color; everything else stays fixed.", "$value": "{color.accent.base}" }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$description": "Impact + UI. From udesign-website.", "$value": ["Montserrat", "sans-serif"] },
      "data":    { "$description": "Technical readouts only: SKU, PMS, dimensions.", "$value": ["JetBrains Mono", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium":  { "$value": 500 },
      "semibold":{ "$value": 600 },
      "bold":    { "$value": 700 },
      "extrabold": { "$value": 800 },
      "black":   { "$value": 900 }
    }
  },

  "typography": {
    "$type": "typography",
    "display": { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.black}", "fontSize": { "value": 3, "unit": "rem" }, "lineHeight": 1, "letterSpacing": { "value": -0.02, "unit": "em" } } },
    "h1":      { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.black}", "fontSize": { "value": 2.1, "unit": "rem" }, "lineHeight": 1.05, "letterSpacing": { "value": -0.01, "unit": "em" } } },
    "h2":      { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.extrabold}", "fontSize": { "value": 1.6, "unit": "rem" }, "lineHeight": 1.1, "letterSpacing": { "value": -0.01, "unit": "em" } } },
    "h3":      { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.bold}", "fontSize": { "value": 1.2, "unit": "rem" }, "lineHeight": 1.2, "letterSpacing": { "value": 0, "unit": "em" } } },
    "body":    { "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.regular}", "fontSize": { "value": 1, "unit": "rem" }, "lineHeight": 1.6, "letterSpacing": { "value": 0, "unit": "em" } } },
    "label":   { "$description": "Quiet Title-case label. Never uppercase, never wide-tracked, never mono.", "$value": { "fontFamily": "{font.family.display}", "fontWeight": "{font.weight.semibold}", "fontSize": { "value": 0.78, "unit": "rem" }, "lineHeight": 1.3, "letterSpacing": { "value": 0, "unit": "em" } } },
    "data":    { "$value": { "fontFamily": "{font.family.data}", "fontWeight": "{font.weight.regular}", "fontSize": { "value": 0.85, "unit": "rem" }, "lineHeight": 1.4, "letterSpacing": { "value": 0, "unit": "em" } } }
  },

  "radius": {
    "$type": "dimension",
    "sm":   { "$value": { "value": 7, "unit": "px" } },
    "base": { "$description": "Shared with globalvision (0.625rem).", "$value": { "value": 10, "unit": "px" } },
    "lg":   { "$value": { "value": 16, "unit": "px" } },
    "pill": { "$value": { "value": 999, "unit": "px" } }
  },

  "space": {
    "$type": "dimension",
    "1": { "$value": { "value": 0.25, "unit": "rem" } },
    "2": { "$value": { "value": 0.5, "unit": "rem" } },
    "3": { "$value": { "value": 0.75, "unit": "rem" } },
    "4": { "$value": { "value": 1, "unit": "rem" } },
    "6": { "$value": { "value": 1.5, "unit": "rem" } },
    "8": { "$value": { "value": 2, "unit": "rem" } }
  },

  "shadow": {
    "$type": "shadow",
    "1": { "$value": { "color": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "alpha": 0.05, "hex": "#1b1b1b" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 1, "unit": "px" }, "blur": { "value": 2, "unit": "px" }, "spread": { "value": 0, "unit": "px" } } },
    "2": { "$value": { "color": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "alpha": 0.28, "hex": "#1b1b1b" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 8, "unit": "px" }, "blur": { "value": 24, "unit": "px" }, "spread": { "value": -14, "unit": "px" } } },
    "3": { "$value": { "color": { "colorSpace": "srgb", "components": [0.106, 0.106, 0.106], "alpha": 0.40, "hex": "#1b1b1b" }, "offsetX": { "value": 0, "unit": "px" }, "offsetY": { "value": 24, "unit": "px" }, "blur": { "value": 60, "unit": "px" }, "spread": { "value": -34, "unit": "px" } } }
  }
}
